# Environment configuration
ENVIRONMENT=production
DEBUG=False
ALLOWED_HOSTS=*

# Database
POSTGRES_USER=craft_user
POSTGRES_PASSWORD=secure_postgres_password_here
POSTGRES_DB=craft_db
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
ASYNC_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Message Broker and Cache
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=secure_rabbitmq_password_here
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672/
REDIS_URL=redis://redis:6379/0

# Internal Service URLs
CATALOG_SERVICE_INTERNAL_URL=http://catalog_service:8002/internal/products/all/

# Security Keys
SECRET_KEY=generate_a_secure_django_secret_key_here

# Stripe Integration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT Keys (RSA base64 encoded strings)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
